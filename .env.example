# Browser-safe values only. Vite exposes every `VITE_` variable to the app.
# For local Supabase, use the API URL and anon key reported by `npx supabase status`.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-or-hosted-anon-key

# Never place service-role keys, JWT secrets, SMTP credentials, or other
# privileged tokens in frontend env files.
